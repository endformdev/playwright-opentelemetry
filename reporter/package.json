{
	"name": "playwright-opentelemetry",
	"version": "0.6.1",
	"description": "A reporter for Playwright that can export traces and spans in opentelemetry format.",
	"type": "module",
	"license": "Apache-2.0",
	"homepage": "https://github.com/endformdev/playwright-opentelemetry#readme",
	"bugs": {
		"url": "https://github.com/endformdev/playwright-opentelemetry/issues"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/endformdev/playwright-opentelemetry"
	},
	"author": "Oliver Stenbom <oliver@endform.dev>",
	"keywords": [
		"playwright",
		"opentelemetry",
		"reporting",
		"testing",
		"automation"
	],
	"files": [
		"dist"
	],
	"main": "./dist/index.mjs",
	"module": "./dist/index.mjs",
	"types": "./dist/index.d.mts",
	"exports": {
		".": {
			"types": "./dist/index.d.mts",
			"import": "./dist/index.mjs",
			"require": "./dist/index.cjs",
			"default": "./dist/index.mjs"
		},
		"./fixture": {
			"types": "./dist/fixture.d.mts",
			"import": "./dist/fixture.mjs",
			"require": "./dist/fixture.cjs",
			"default": "./dist/fixture.mjs"
		},
		"./fixture/factory": {
			"types": "./dist/fixture/factory.d.mts",
			"import": "./dist/fixture/factory.mjs",
			"require": "./dist/fixture/factory.cjs",
			"default": "./dist/fixture/factory.mjs"
		},
		"./reporter": {
			"types": "./dist/reporter.d.mts",
			"import": "./dist/reporter.mjs",
			"require": "./dist/reporter.cjs",
			"default": "./dist/reporter.mjs"
		},
		"./package.json": "./package.json"
	},
	"scripts": {
		"build": "tsdown",
		"dev": "tsdown --watch",
		"test:e2e": "pnpm build && pnpm playwright test",
		"verify:trace-zips": "bun scripts/verify-trace-zips.ts"
	},
	"peerDependencies": {
		"@playwright/test": "*"
	},
	"dependencies": {
		"@rrweb/record": "catalog:",
		"@rrweb/types": "catalog:",
		"@zip.js/zip.js": "catalog:"
	},
	"devDependencies": {
		"@biomejs/biome": "catalog:",
		"@playwright/test": "catalog:",
		"@types/bun": "^1.3.14",
		"@types/node": "catalog:",
		"tsdown": "catalog:"
	}
}
